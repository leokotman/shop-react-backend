{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/product-service.schema.json",
  "title": "Product Service (DynamoDB)",
  "description": "Base URL includes stage (e.g. ...amazonaws.com/prod/). GET responses join products and stock.",
  "endpoints": {
    "GET /products": {
      "response": {
        "200": { "$ref": "#/$defs/ProductList" },
        "500": { "$ref": "#/$defs/ErrorMessage" }
      }
    },
    "GET /products/{productId}": {
      "pathParameters": {
        "productId": {
          "type": "string",
          "description": "Product id (UUID in mock data)"
        }
      },
      "responses": {
        "200": { "$ref": "#/$defs/Product" },
        "400": {
          "type": "object",
          "properties": {
            "message": { "const": "Missing productId" }
          },
          "required": ["message"]
        },
        "404": {
          "type": "object",
          "properties": {
            "message": { "const": "Product not found" }
          },
          "required": ["message"]
        },
        "500": { "$ref": "#/$defs/ErrorMessage" }
      }
    },
    "POST /products": {
      "requestBody": {
        "type": "object",
        "required": ["title", "price", "count"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "price": { "type": "integer", "minimum": 0 },
          "count": { "type": "integer", "minimum": 0 }
        }
      },
      "responses": {
        "201": { "$ref": "#/$defs/Product" },
        "400": { "$ref": "#/$defs/ErrorMessage" },
        "500": { "$ref": "#/$defs/ErrorMessage" }
      }
    }
  },
  "$defs": {
    "ErrorMessage": {
      "type": "object",
      "properties": {
        "message": { "type": "string" }
      },
      "required": ["message"]
    },
    "Product": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "price", "count"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "count": { "type": "integer", "minimum": 0 }
      }
    },
    "ProductList": {
      "type": "array",
      "items": { "$ref": "#/$defs/Product" }
    }
  }
}
